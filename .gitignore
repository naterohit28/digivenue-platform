# ── Backups / large archives (don't belong in git) ──
*.zip

# ── Secrets — never commit API keys ──
**/configs/secrets.local.json
.env

# ── Python ──
__pycache__/
*.pyc
.venv/
venv/

# ── Local databases & generated runtime data ──
*.db
*.log
**/logs/*.log
chrome_debug.log

# ── Per-run snapshot dumps (redundant with latest_scored_snapshot.json) ──
**/historical/scored_snapshot_*.json

# ── OS / editor junk ──
Thumbs.db
.DS_Store
*.deprecated
